0000a\u0000 \u0000c\u0000l\u0000e\u0000a\u0000n\u0000 \u0000a\u0000b\u0000s\u0000t\u0000r\u0000a\u0000c\u0000t\u0000i\u0000o\u0000n\u0000 \u0000t\u0000o\u0000 \u0000s\u0000w\u0000a\u0000p\u0000 \u0000i\u0000n\u0000 \u0000R\u0000e\u0000d\u0000i\u0000s\u0000 \u0000f\u0000o\u0000r\u0000 \u0000d\u0000i\u0000s\u0000t\u0000r\u0000i\u0000b\u0000u\u0000t\u0000e\u0000d\u0000 \u0000d\u0000e\u0000p\u0000l\u0000o\u0000y\u0000m\u0000e\u0000n\u0000t\u0000s\u0000.\u0000\r\u0000 \u0000\r\u0000 \u0000\"  \u0000I\u0000m\u0000p\u0000l\u0000e\u0000m\u0000e\u0000n\u0000t\u0000e\u0000d\u0000 \u0000l\u0000a\u0000z\u0000y\u0000-\u0000r\u0000e\u0000f\u0000i\u0000l\u0000l\u0000 \u0000l\u0000o\u0000g\u0000i\u0000c\u0000 \u0000u\u0000s\u0000i\u0000n\u0000g\u0000 \u0000e\u0000l\u0000a\u0000p\u0000s\u0000e\u0000d\u0000-\u0000t\u0000i\u0000m\u0000e\u0000 \u0000c\u0000a\u0000l\u0000c\u0000u\u0000l\u0000a\u0000t\u0000i\u0000o\u0000n\u0000s\u0000 \u0000\u0014  \u0000n\u0000o\u0000 \u0000b\u0000a\u0000c\u0000k\u0000g\u0000r\u0000o\u0000u\u0000n\u0000d\u0000 \u0000t\u0000i\u0000m\u0000e\u0000r\u0000s\u0000 \u0000\u0014  \u0000e\u0000n\u0000s\u0000u\u0000r\u0000i\u0000n\u0000g\u0000 \u0000a\u0000c\u0000c\u0000u\u0000r\u0000a\u0000t\u0000e\u0000 \u0000t\u0000o\u0000k\u0000e\u0000n\u0000 \u0000r\u0000e\u0000p\u0000l\u0000e\u0000n\u0000i\u0000s\u0000h\u0000m\u0000e\u0000n\u0000t\u0000 \u0000w\u0000i\u0000t\u0000h\u0000 \u0000z\u0000e\u0000r\u0000o\u0000 \u0000p\u0000o\u0000l\u0000l\u0000i\u0000n\u0000g\u0000 \u0000o\u0000v\u0000e\u0000r\u0000h\u0000e\u0000a\u0000d\u0000.\u0000\r\u0000 \u0000\r\u0000 \u0000\"  \u0000E\u0000x\u0000p\u0000o\u0000s\u0000e\u0000d\u0000 \u0000s\u0000t\u0000a\u0000n\u0000d\u0000a\u0000r\u0000d\u0000 \u0000H\u0000T\u0000T\u0000P\u0000 \u0000r\u0000a\u0000t\u0000e\u0000-\u0000l\u0000i\u0000m\u0000i\u0000t\u0000 \u0000h\u0000e\u0000a\u0000d\u0000e\u0000r\u0000s\u0000 \u0000(\u0000X\u0000-\u0000R\u0000a\u0000t\u0000e\u0000L\u0000i\u0000m\u0000i\u0000t\u0000-\u0000L\u0000i\u0000m\u0000i\u0000t\u0000,\u0000 \u0000X\u0000-\u0000R\u0000a\u0000t\u0000e\u0000L\u0000i\u0000m\u0000i\u0000t\u0000-\u0000R\u0000e\u0000m\u0000a\u0000i\u0000n\u0000i\u0000n\u0000g\u0000)\u0000 \u0000g\u0000i\u0000v\u0000i\u0000n\u0000g\u0000 \u0000A\u0000P\u0000I\u0000 \u0000c\u0000o\u0000n\u0000s\u0000u\u0000m\u0000e\u0000r\u0000s\u0000 \u0000r\u0000e\u0000a\u0000l\u0000-\u0000t\u0000i\u0000m\u0000e\u0000 \u0000q\u0000u\u0000o\u0000t\u0000a\u0000 \u0000v\u0000i\u0000s\u0000i\u0000b\u0000i\u0000l\u0000i\u0000t\u0000y\u0000.\u0000\r\u0000 \u0000\r\u0000 \u0000\"  \u0000W\u0000r\u0000o\u0000t\u0000e\u0000 \u0000u\u0000n\u0000i\u0000t\u0000 \u0000t\u0000e\u0000s\u0000t\u0000s\u0000 \u0000w\u0000i\u0000t\u0000h\u0000 \u0000J\u0000e\u0000s\u0000t\u0000 \u0000c\u0000o\u0000v\u0000e\u0000r\u0000i\u0000n\u0000g\u0000 \u0000t\u0000o\u0000k\u0000e\u0000n\u0000 \u0000c\u0000o\u0000n\u0000s\u0000u\u0000m\u0000p\u0000t\u0000i\u0000o\u0000n\u0000,\u0000 \u0000r\u0000e\u0000f\u0000i\u0000l\u0000l\u0000 \u0000a\u0000c\u0000c\u0000u\u0000r\u0000a\u0000c\u0000y\u0000,\u0000 \u0000a\u0000n\u0000d\u0000 \u0000e\u0000d\u0000g\u0000e\u0000 \u0000c\u0000a\u0000s\u0000e\u0000s\u0000 \u0000l\u0000i\u0000k\u0000e\u0000 \u0000o\u0000v\u0000e\u0000r\u0000f\u0000l\u0000o\u0000w\u0000 \u0000p\u0000r\u0000e\u0000v\u0000e\u0000n\u0000t\u0000i\u0000o\u0000n\u0000 \u0000a\u0000n\u0000d\u0000 \u0000e\u0000m\u0000p\u0000t\u0000y\u0000-\u0000b\u0000u\u0000c\u0000k\u0000e\u0000t\u0000 \u0000r\u0000e\u0000j\u0000e\u0000c\u0000t\u0000i\u0000o\u0000n\u0000.\u0000\r\u0000 \u0000\r\u0000 \u0000\r\u0000 \u0000",
